{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sta-backend.sta-tw.workers.dev/api/:path*"
    },
    {
      "source": "/ws",
      "destination": "https://sta-backend.sta-tw.workers.dev/ws"
    },
    {
      "source": "/health",
      "destination": "https://sta-backend.sta-tw.workers.dev/health"
    }
  ]
}
