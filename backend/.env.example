# App
APP_NAME=STA Platform
DEBUG=false
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database (asyncpg)
DATABASE_URL=postgresql+asyncpg://sta:stapassword@localhost:5432/sta

# Redis
REDIS_URL=redis://localhost:6379

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS / Frontend
FRONTEND_URL=http://localhost:12003

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# SMTP (optional — if empty, emails are printed to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@sta.tw
